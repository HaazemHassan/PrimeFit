# ========================================
# PrimeFit Environment Configuration
# ========================================
# Copy this file to .env and update with your own values




# ========================================
# Database Configuration
# ========================================
DB_SERVER=sqlserver
DB_PORT=1433
DB_NAME=PrimeFit
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!

# ========================================
# JWT Authentication Settings
# ========================================
JWT_SECRET=YourVeryLongAndSecureJWTSecretKeyThatIsAtLeast32CharactersLong
JWT_ISSUER=https://localhost:7153
JWT_AUDIENCE=https://localhost:4200
JWT_VALIDATE_AUDIENCE=false
JWT_VALIDATE_ISSUER=true
JWT_VALIDATE_LIFETIME=true
JWT_VALIDATE_ISSUER_SIGNING_KEY=true
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=43200
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30


# ========================================
# Password Policy Settings
# ========================================
PASSWORD_MIN_LENGTH=3
PASSWORD_MAX_LENGTH=20
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_NON_ALPHANUMERIC=false
PASSWORD_REQUIRED_UNIQUE_CHARS=1

# ========================================
# Rate Limiting Settings
# ========================================
# Default Rate Limiter
RATE_LIMIT_DEFAULT_WINDOW_MINUTES=1
RATE_LIMIT_DEFAULT_PERMIT_LIMIT=90
RATE_LIMIT_DEFAULT_QUEUE_LIMIT=10
RATE_LIMIT_DEFAULT_SEGMENTS=4

# Login Rate Limiter
RATE_LIMIT_LOGIN_WINDOW_MINUTES=1
RATE_LIMIT_LOGIN_PERMIT_LIMIT=5
RATE_LIMIT_LOGIN_QUEUE_LIMIT=0
RATE_LIMIT_LOGIN_SEGMENTS=4
RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ========================================
# Serilog Settings
# ========================================
SERILOG_MINIMUM_LEVEL_DEFAULT=
SERILOG_MINIMUM_LEVEL_MICROSOFT_ASPNETCORE=
SERILOG_FILE_PATH=
SERILOG_FILE_ROLLING_INTERVAL=
SERILOG_FILE_FORMATTER=
SERILOG_APPLICATION_NAME=

# ========================================
# Hangfire Settings
# ========================================
HANGFIRE_DASHBOARD_PATH=
HANGFIRE_DASHBOARD_USERNAME=
HANGFIRE_DASHBOARD_PASSWORD=

# ========================================
# Cloudinary Settings
# ========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========================================
# Mail Settings
# ========================================
MAIL_DISPLAY_NAME=
MAIL_ADDRESS=
MAIL_PASSWORD=
MAIL_HOST=
MAIL_PORT=

# ========================================
# Verification Code Settings
# ========================================
VERIFICATION_EMAIL_EXPIRE_IN_MINUTES=
VERIFICATION_CODE_LENGTH=

# ========================================
# Google Auth Settings
# ========================================
GOOGLE_AUTH_CLIENT_ID=

# ========================================
# Application Ports
# ========================================
DB_EXTERNAL_PORT=15000
API_EXTERNAL_PORT=44000